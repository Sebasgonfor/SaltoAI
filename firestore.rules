rules_version = '2';

// DEMO ONLY — reglas abiertas para el hackatón.
// Antes de cualquier piloto real, restringir por auth y por colección
// (ver PRD §8.5 "Privacidad" + Roadmap del README).
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{profileId} {
      allow read, write: if true;
    }
    match /needs/{needId} {
      allow read, write: if true;
    }
    // Feedback loop (PRD §6.2.6, §8.6). Data flywheel propietario —
    // queremos write desde la app pública, y read solo para auditoría.
    match /feedback/{feedbackId} {
      allow read, write: if true;
    }
  }
}
